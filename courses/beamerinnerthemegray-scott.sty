\mode<presentation>

% Background title page
\setbeamertemplate{background titlepage}{
    \begin{tikzpicture}[overlay, remember picture]
        \node[
            inner sep=0pt,
            outer sep=0pt,
            anchor=north east
        ] at (current page.north east) {
            \includegraphics[
                width=\the\paperwidth,
                height=\the\paperheight
            ]{gray_scott.jpg}
        };
    \end{tikzpicture}
}

% Background
\setbeamertemplate{background}{
    \begin{tikzpicture}[overlay, remember picture]
        \node[
            inner sep=0pt,
            outer sep=0pt,
            anchor=north east
        ] at (current page.north east) {
            \includegraphics[
                width=\the\paperwidth,
                height=\the\paperheight
            ]{gray_scott_empty.jpg}
        };
        \fill[color=white] (0em, -2em) rectangle (\the\paperwidth, -\the\paperheight + 1.5em);
    \end{tikzpicture}
}

% Background exercise page
\setbeamertemplate{background exercisepage}{
    \begin{tikzpicture}[overlay, remember picture]
        \node[
            inner sep=0pt,
            outer sep=0pt,
            anchor=north east
        ] at (current page.north east) {
            \includegraphics[
            width=\the\paperwidth,
            height=\the\paperheight
            ]{gray_scott_empty.jpg}
        };
    \end{tikzpicture}
}

% Title page
\defbeamertemplate*{title page}{gray-scott}{%
    \usebeamertemplate{background titlepage}%
    \vskip2cm%
    \begin{beamercolorbox}[center]{title page header}
        \usebeamerfont{title page header}\inserttitle%
    \end{beamercolorbox}%
    \vskip0.1cm%
    \begin{beamercolorbox}[center]{title page subtitle}
        \usebeamerfont{title page subtitle}\insertsubtitle%
    \end{beamercolorbox}%
    \vskip0.3cm%
    \begin{beamercolorbox}[center]{author}
        \usebeamerfont{author}\insertauthor%
    \end{beamercolorbox}%
    \vskip0.1cm%
    \begin{beamercolorbox}[center]{institute}
    \usebeamerfont{author}\insertinstitute%
    \end{beamercolorbox}
    \vskip0.2cm%
    \begin{beamercolorbox}[center]{date}
        \usebeamerfont{author}\insertdate%
    \end{beamercolorbox}
    \vfill%
    \begin{beamercolorbox}[right]{title page version}%
        \usebeamerfont{title page version}\insertversion
    \end{beamercolorbox}
}

% Closing page
\defbeamertemplate*{closing page}{gray-scott}{%
    \usebeamertemplate{background titlepage}%
    \vskip2cm%
    \begin{beamercolorbox}[center]{title page header}
        \usebeamerfont{title page header}That's all folks!%
    \end{beamercolorbox}%
    \vskip0.6cm%
    \begin{beamercolorbox}[center]{normal text}
        \usebeamerfont{normal text}\insertclosing%
    \end{beamercolorbox}%
    \vfill
}

\mode<all>