\mode<presentation>

% Requirement
\RequirePackage{xcolor}
\RequirePackage{tikz}
\usetikzlibrary{positioning,calc}
\RequirePackage{graphicx}
\RequirePackage[no-math]{fontspec}
\RequirePackage[most]{tcolorbox}
\RequirePackage{array}
\RequirePackage{colortbl}

\newfontfamily{\gsfont}{norwester}[Extension = .otf]

\useinnertheme{gray-scott}
\useoutertheme{gray-scott}
\usecolortheme{gray-scott}

\mode<all>

\renewenvironment{block}[1]{%
    \begin{tcolorbox}[
        enhanced,
        boxsep=0.15cm,
        left=0cm,
        right=0cm,
        top=0cm,
        bottom=0cm,
        title={\usebeamerfont{block title}#1},
        frame style tile={width=\paperwidth, trim={30cm 0 0 25cm}, clip}{gray_scott.jpg}
    ]
}{
    \end{tcolorbox}
}

\renewenvironment{alertblock}[1]{%
    \begin{tcolorbox}[
        enhanced,
        boxsep=0.15cm,
        left=0cm,
        right=0cm,
        top=0cm,
        bottom=0cm,
        title={\usebeamerfont{block title alerted}#1},
        frame style tile={width=\paperwidth, trim={30cm 0 0 25cm}, clip}{gray_scott_alert.jpg}
        ]
    }{
    \end{tcolorbox}
}

\renewenvironment{exampleblock}[1]{%
    \begin{tcolorbox}[
        enhanced,
        boxsep=0.15cm,
        left=0cm,
        right=0cm,
        top=0cm,
        bottom=0cm,
        title={\usebeamerfont{block title example}#1},
        frame style tile={width=\paperwidth, trim={30cm 0 0 25cm}, clip}{gray_scott_example.jpg}
        ]
    }{
    \end{tcolorbox}
}

\renewenvironment{table}[2]{%
    \begin{tcolorbox}[
        enhanced,
        boxsep=0cm,
        left=0.15cm,
        right=0.15cm,
        top=0cm,
        bottom=0cm,
        clip upper,
        colframe=darkmain,
        title={\usebeamerfont{block title}#1},
        tabulars*={\arrayrulewidth0.5mm\renewcommand\arraystretch{1.3}}{#2},
        frame style tile={width=\paperwidth, trim={30cm 0 0 25cm}, clip}{gray_scott.jpg}
        ]
}{%
    \end{tcolorbox}
}