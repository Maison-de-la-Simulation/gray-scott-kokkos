% Gray-Scott School theme
%
% Based on the work of Tobias Bora: https://tex.stackexchange.com/a/637801/301699 (CC BY-SA 4.0)

\mode<presentation>

% Requirement
\RequirePackage{xcolor}
\RequirePackage{tikz}
\usetikzlibrary{positioning,calc}
\RequirePackage{graphicx}
\RequirePackage[no-math]{fontspec}
\RequirePackage[most]{tcolorbox}
\RequirePackage{array}
\RequirePackage{colortbl}

\newfontfamily{\gsfont}{norwester}[Extension = .otf]

\useinnertheme{gray-scott}
\useoutertheme{gray-scott}
\usecolortheme{gray-scott}

\mode<all>

\renewenvironment{block}[1]{%
    \begin{tcolorbox}[
        enhanced,
        boxsep=0.15cm,
        left=0cm,
        right=0cm,
        top=0cm,
        bottom=0cm,
        title={\usebeamerfont{block title}#1},
        frame style tile={width=\paperwidth, trim={30cm 0 0 25cm}, clip}{gray_scott.jpg}
    ]
}{
    \end{tcolorbox}
}

\renewenvironment{alertblock}[1]{%
    \setbeamercolor*{itemize item}{fg=main-alert}%
    \setbeamercolor*{itemize subitem}{fg=main-alert}%
    \setbeamercolor*{enumerate item}{fg=main-alert}%
    \setbeamercolor*{enumerate subitem}{fg=main-alert}%
    \setbeamercolor*{description item}{fg=main-alert}%
    \setbeamercolor*{description subitem}{fg=main-alert}%
    \begin{tcolorbox}[
        enhanced,
        boxsep=0.15cm,
        left=0cm,
        right=0cm,
        top=0cm,
        bottom=0cm,
        title={\usebeamerfont{block title alerted}#1},
        frame style tile={width=\paperwidth, trim={30cm 0 0 25cm}, clip}{gray_scott_alert.jpg}
        ]
    }{
    \end{tcolorbox}
}

\renewenvironment{exampleblock}[1]{%
    \setbeamercolor*{itemize item}{fg=main-example}%
    \setbeamercolor*{itemize subitem}{fg=main-example}%
    \setbeamercolor*{enumerate item}{fg=main-example}%
    \setbeamercolor*{enumerate subitem}{fg=main-example}%
    \setbeamercolor*{description item}{fg=main-example}%
    \setbeamercolor*{description subitem}{fg=main-example}%
    \begin{tcolorbox}[
        enhanced,
        boxsep=0.15cm,
        left=0cm,
        right=0cm,
        top=0cm,
        bottom=0cm,
        title={\usebeamerfont{block title example}#1},
        frame style tile={width=\paperwidth, trim={30cm 0 0 25cm}, clip}{gray_scott_example.jpg}
        ]
    }{
    \end{tcolorbox}
}

\renewenvironment{table}[2]{%
    \begin{tcolorbox}[
        enhanced,
        boxsep=0cm,
        left=0.15cm,
        right=0.15cm,
        top=0cm,
        bottom=0cm,
        clip upper,
        colframe=darkmain,
        title={\usebeamerfont{block title}#1},
        tabulars*={\arrayrulewidth0.5mm\renewcommand\arraystretch{1.3}}{#2},
        frame style tile={width=\paperwidth, trim={30cm 0 0 25cm}, clip}{gray_scott.jpg}
        ]
}{%
    \end{tcolorbox}
}

% Exercise frame
\newenvironment{exerciseframe}[1]{%
    \setbeamertemplate{background}{\usebeamertemplate{background exercisepage}}%
    \setbeamercolor*{structure}{fg=lightmain}%
    \setbeamercolor*{normal text}{fg=white}%
    \setbeamercolor*{itemize item}{fg=lightmain}%
    \setbeamercolor*{itemize subitem}{fg=lightmain}%
    \setbeamercolor*{enumerate item}{fg=lightmain}%
    \setbeamercolor*{enumerate subitem}{fg=lightmain}%
    \setbeamercolor*{description item}{fg=lightmain}%
    \setbeamercolor*{description subitem}{fg=lightmain}%
    \begin{frame}[environment=exerciseframe, fragile]{Exercise: #1}
        \begin{beamercolorbox}{normal text}
}{%
        \end{beamercolorbox}
    \end{frame}%
}

\def\insertclosing{}
\newcommand{\closing}[1]{\def\insertclosing{#1}}

% Closing page
\newcommand{\closingpage}{%
    \setbeamercolor*{structure}{fg=white}%
    \setbeamercolor*{normal text}{fg=white}%
    \setbeamercolor*{itemize item}{fg=white}%
    \setbeamercolor*{itemize subitem}{fg=white}%
    \setbeamercolor*{enumerate item}{fg=white}%
    \setbeamercolor*{enumerate subitem}{fg=white}%
    \setbeamercolor*{description item}{fg=white}%
    \setbeamercolor*{description subitem}{fg=white}%
    \usebeamertemplate{closing page}%
}