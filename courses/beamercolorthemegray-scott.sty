% base color
\definecolor{gs}{RGB}{10, 66, 127}

% colors
\colorlet{main}{gs}
\colorlet{lightmain}{main!30}
\colorlet{darkmain}{main!90!black}
\colorlet{dimmedmain}{main!50}
\colorlet{lightgray}{gray!20}
\colorlet{darkgray}{gray!70!black}

\mode<presentation>

\setbeamercolor*{title page header}{fg=white}
\setbeamercolor*{title page subtitle}{fg=white}
\setbeamercolor*{author}{fg=white}
\setbeamercolor*{date}{fg=white}
\setbeamercolor*{item}{fg=black}
\setbeamercolor*{navigation symbols}{fg=white}
\setbeamercolor*{navigation symbols dimmed}{fg=lightmain}
\setbeamercolor*{structure}{fg=main}
\setbeamercolor*{alerted text}{fg=alert}
\setbeamercolor*{title in head/foot}{fg=white}
\setbeamercolor*{section in head/foot}{fg=white}
\setbeamercolor*{subsection in head/foot}{fg=white}
\setbeamercolor*{institute}{fg=white}
\setbeamercolor*{frametitle}{fg=white}
\setbeamercolor*{page number in head/foot}{fg=white}
\setbeamercolor*{block title}{fg=white}
\setbeamercolor*{block body}{fg=black, bg=lightmain}
\setbeamercolor*{block title alerted}{fg=white}
\setbeamercolor*{block body alerted}{fg=black, bg=white}
\setbeamercolor*{block title example}{fg=white}
\setbeamercolor*{block body example}{fg=black, bg=white}
\setbeamercolor*{itemize item}{fg=main}
\setbeamercolor*{itemize subitem}{fg=main}
\setbeamercolor*{enumerate item}{fg=main}
\setbeamercolor*{enumerate subitem}{fg=main}
\setbeamercolor*{description item}{fg=main}
\setbeamercolor*{description subitem}{fg=main}
\setbeamercolor*{footline}{fg=white}

\setbeamerfont{title page header}{family=\gsfont, size=\Huge}
\setbeamerfont{title page subtitle}{family=\gsfont, size=\footnotesize}
\setbeamerfont{frametitle}{family=\gsfont}
\setbeamerfont{footline}{family=\gsfont, size=\tiny}
\setbeamerfont{author}{series=\bfseries, size=\scriptsize}
\setbeamerfont{date}{series=\bfseries}
\setbeamerfont{subsection in head/foot}{series=\bfseries}
\setbeamerfont{enumerate item}{family=\gsfont, size=\small}
\setbeamerfont{enumerate subitem}{family=\gsfont, size=\small}
\setbeamerfont{description item}{family=\gsfont, size=\footnotesize}
\setbeamerfont{description subitem}{family=\gsfont, size=\footnotesize}
\setbeamerfont{block title}{family=\gsfont, size=\footnotesize}
\setbeamerfont{page number in head/foot}{family=\gsfont, size=\footnotesize}

\mode<all>